package clawmaster:text-join@0.1.0;

/// Text joining tool for Moltis AI agents.
///
/// This tool provides text joining operations.
///
/// # Compliance
/// DO-178C §6.3.2: Error handling - All operations return Result types
/// DO-178C §11.10: Resource management - Output size limits enforced
world text-join {
    /// Join text parts with delimiter.
    ///
    /// # Arguments
    /// * `parts` - List of text parts to join
    /// * `delimiter` - Delimiter string
    ///
    /// # Returns
    /// * `Ok(joined)` - Joined text
    /// * `Err(message)` - Error message if joining fails
    ///
    /// # Compliance
    /// DO-178C §6.3.2: All errors properly handled
    /// DO-178C §6.3.4: Deterministic joining
    export join: func(parts: list<string>, delimiter: string) -> result<string, string>;
    
    /// Join text parts with newlines.
    ///
    /// # Arguments
    /// * `lines` - List of lines to join
    ///
    /// # Returns
    /// * `Ok(text)` - Joined text
    /// * `Err(message)` - Error message
    export join-lines: func(lines: list<string>) -> result<string, string>;
    
    /// Join text parts with spaces.
    ///
    /// # Arguments
    /// * `words` - List of words to join
    ///
    /// # Returns
    /// * `Ok(text)` - Joined text
    /// * `Err(message)` - Error message
    export join-words: func(words: list<string>) -> result<string, string>;
    
    /// Concatenate text parts (no delimiter).
    ///
    /// # Arguments
    /// * `parts` - List of text parts
    ///
    /// # Returns
    /// * `Ok(text)` - Concatenated text
    /// * `Err(message)` - Error message
    export concat: func(parts: list<string>) -> result<string, string>;
}
